# Azure AI Foundry Configuration
AZURE_AI_FOUNDRY_ENDPOINT=https://your-ai-services-resource.services.ai.azure.com/api/projects/your-project
AZURE_AI_FOUNDRY_API_KEY=your-api-key-or-bearer-token
AZURE_AI_AGENT_NAME=your-agent-name
AZURE_AI_AGENT_VERSION=

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Optional WhatsApp Cloud API Configuration
# Leave blank for the free demo path. Telegram remains the recommended free real-send channel.
WHATSAPP_ACCESS_TOKEN=your-whatsapp-cloud-api-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_RECIPIENT_PHONE=recipient-phone-with-country-code
WHATSAPP_GRAPH_API_VERSION=v23.0

# Optional abuse-protection tuning for /api/send-alert (sensible defaults apply).
# GUARDIAN_ALERT_RATE_MAX: max alert sends per IP per window (default 8)
# GUARDIAN_ALERT_RATE_WINDOW_MS: sliding window length in ms (default 300000 = 5 min)
# GUARDIAN_DISABLE_ORIGIN_CHECK: set to "true" to bypass same-origin enforcement
#   (only for local curl testing or trusted server-to-server callers)
GUARDIAN_ALERT_RATE_MAX=8
GUARDIAN_ALERT_RATE_WINDOW_MS=300000
GUARDIAN_DISABLE_ORIGIN_CHECK=false
